{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "required": [
        "timezone",
        "server_time"
    ],
    "properties": {
        "timezone": {
            "type": "string"
        },
        "server_time": {
            "type": "integer",
            "minimum": 1
        }
    }
}