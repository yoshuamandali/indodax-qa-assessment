{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "required": ["date", "price", "amount", "tid", "type"],
        "additionalProperties": true,
        "properties": {
            "date":   { "type": "string" },
            "price":  { "type": "string" },
            "amount": { "type": "string" },
            "tid":    { "type": "string" },
            "type":   { "type": "string", "enum": ["buy", "sell"] }
        }
    }
}
